# ADMIN FALLBACK - Used when OIDC unavailable or for emergency local login
FILEBROWSER_ADMIN_USERNAME=admin
FILEBROWSER_ADMIN_PASSWORD=ChangeMeNow

# OIDC KEYCLOAK - Your authentication provider settings
FILEBROWSER_OIDC_CLIENT_ID=filebrowser
FILEBROWSER_OIDC_CLIENT_SECRET=YOUR_KEYCLOAK_CLIENT_SECRET_HERE

# JWT SECURITY - Signing key for session tokens, generate with: openssl rand -base64 32
FILEBROWSER_JWT_TOKEN_SECRET=GENERATE_A_32_CHAR_RANDOM_STRING_HERE

# INTERNAL PATHS - Container paths, usually no need to change
FILEBROWSER_DATABASE=/home/filebrowser/data/database.db
FILEBROWSER_CACHE_DIR=/home/filebrowser/data/tmp
